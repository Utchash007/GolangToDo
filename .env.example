# Required
PORT=8080
DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional — connection pool settings (defaults apply if absent)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_IDLE_TIME=5m

# Note: copy this file to .env and fill in real values.
# DATABASE_URL must be set for DB integration tests to run.
